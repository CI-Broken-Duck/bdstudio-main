<section class="about-section">
  <h1 class="about-heading">What Clients Say About Us</h1>
  <p class="about-subheading">From tutoring centers to startups, we build the tools they need</p>

  <div class="testimonial-scroll-mask">
    <div class="testimonial-grid">
      {testimonials.map((user, index) => (
        <div class="testimonial-card" key={index}>
          <p class="testimonial-quote" set:html={user.quote}></p>
          <div class="testimonial-footer">
            <img src={user.avatar} alt={user.name} class="testimonial-avatar" />
            <div>
              <div class="testimonial-name">{user.name}</div>
              <div class="testimonial-role">{user.role}</div>
            </div>
          </div>
          <div class="testimonial-stars" aria-label="5 stars">
            &#9733;&#9733;&#9733;&#9733;&#9733;
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
