---
import "./Shero.css";
---

<section id="slanding" class="slanding-section">
  <div class="slanding-container">
    <div class="slanding-text">
      <h2 class="slanding-heading">
        Membership Designed for Serious YouTube Creators
      </h2>
      <p class="slanding-subheading">
        Join a focused creative space built for consistency, production, and growth. Get 24-hour access to studios, workshops, and a small, supportive community that helps you stay on track.
      </p>
      <a href="/facility" class="quote-button">View Facilities</a>
    </div>

    <div class="slanding-video-wrapper">
      <video
        class="slanding-video"
        src="/assets/videos/build.mp4"
        autoplay
        loop
        muted
        playsinline
      ></video>
    </div>
  </div>
</section>
