---
import "../styles/global.css";
import "../styles/package.css";
import Header from "../components/Header/Header.astro";
import Footer from "../components/Footer/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Partner Program | Broken Duck Studio</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>

  <body>
    <Header />

    <main class="package-section">
      <div class="package-container">
        <!-- Hero Section -->
        <section class="package-row">
          <div class="package-text">
            <h1 class="package-heading">MCN & Partner Program</h1>
            <p class="package-paragraph">
              Broken Duck Studio is developing a YouTube Partner Program for monetized creators in Northern Thailand. This future service will offer direct channel support, strategy coaching, monetization management, and access to premium studio and post-production resources — all under a transparent, creator-first MCN model.
            </p>
          </div>
          <img
            src="/assets/packages/Studio.png"
            alt="Partner illustration"
            class="package-image"
          />
        </section>

        <!-- What Is It -->
        <section>
          <h2 class="package-heading" style="text-align: left;">What is a Partner MCN?</h2>
          <p class="package-paragraph">
            A Multi-Channel Network (MCN) helps creators grow by providing services that YouTube doesn’t offer directly — from brand deals and monetization help to editing support, channel audits, or content planning. MCNs work with YouTube on your behalf, and give you a team behind your content.
          </p>
        </section>

        <!-- What We're Building -->
        <section>
          <h2 class="package-heading" style="text-align: left;">What We're Planning</h2>
          <ul class="package-list">
            <li>Transparent monetization split with no lock-in contracts</li>
            <li>Channel growth reviews and 1:1 content strategy</li>
            <li>Thumbnail and title optimization support</li>
            <li>Monthly performance reports and recommendations</li>
            <li>Access to studio editing team (optional)</li>
            <li>Priority event and booking access</li>
          </ul>
        </section>

        <!-- Who It's For -->
        <section>
          <h2 class="package-heading" style="text-align: left;">Who This Is For</h2>
          <ul class="package-list">
            <li>Monetized creators in Thailand earning ad revenue</li>
            <li>Full-time or part-time YouTubers looking to grow</li>
            <li>Channels publishing consistently with long-term goals</li>
            <li>Creators who want real help without complicated contracts</li>
          </ul>
        </section>

        <!-- Status -->
        <section>
          <h2 class="package-heading" style="text-align: left;">Current Status</h2>
          <p class="package-paragraph">
            This program is <strong>not yet active</strong>. We're building relationships with YouTube and regional MCN providers, and finalizing what tools and services we can offer. If you're interested in joining once it launches, we'd love to hear from you.
          </p>
        </section>

        <!-- Contact -->
        <section>
          <h2 class="package-heading" style="text-align: left;">Want Early Access?</h2>
          <p class="package-paragraph">
            If you’re a monetized creator based in Thailand and want to be part of the first group to join, send us a message with your channel link and a short note about your goals.
          </p>
          <p class="package-paragraph">
            <strong>Email:</strong> <a href="mailto:admin@brokenduckmedia.com">admin@brokenduckmedia.com</a>
          </p>
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>
