---
import "../styles/global.css";
import "../styles/package.css";
import Header from "../components/Header/Header.astro";
import Footer from "../components/Footer/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Equipment Rental | Broken Duck Studio</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>

  <body>
    <Header />

    <main class="package-section">
      <div class="package-container">
        <!-- Hero Section -->
        <section class="package-row">
          <div class="package-text">
            <h1 class="package-heading">Equipment Rentals</h1>
            <p class="package-paragraph">
              Broken Duck Studio members and production clients can rent professional gear through our partner, <strong>Green Light Studio</strong>. Whether you’re filming interviews, short-form content, or running a multicam shoot — we’ve got high-quality equipment ready to go.
            </p>
          </div>
          <img
            src="/assets/packages/Studio.png"
            alt="Equipment rental illustration"
            class="package-image"
          />
        </section>

        <!-- Camera Gear -->
        <section>
          <h2 class="package-heading" style="text-align: left;">Cameras & Video</h2>
          <ul class="package-list">
            <li><strong>Sony ZV-E10 (4K Mirrorless)</strong> – 600 THB/day</li>
            <li><strong>Canon EOS R10 (APS-C, 4K60)</strong> – 800 THB/day</li>
            <li><strong>Blackmagic Pocket Cinema Camera 6K</strong> – 1,200 THB/day</li>
            <li><strong>Elgato Cam Link 4K (USB Capture)</strong> – 300 THB/day</li>
          </ul>
        </section>

        <!-- Audio -->
        <section>
          <h2 class="package-heading" style="text-align: left;">Microphones & Audio</h2>
          <ul class="package-list">
            <li><strong>Rode NT1-A (Condenser Mic + Stand)</strong> – 400 THB/day</li>
            <li><strong>Shure SM7B (Dynamic Broadcast Mic)</strong> – 700 THB/day</li>
            <li><strong>Zoom H5 Field Recorder</strong> – 400 THB/day</li>
            <li><strong>Rode Wireless GO II (Lavalier Pair)</strong> – 500 THB/day</li>
          </ul>
        </section>

        <!-- Teleprompter -->
        <section>
          <h2 class="package-heading" style="text-align: left;">Teleprompter & Accessories</h2>
          <ul class="package-list">
            <li><strong>Desview T3 Teleprompter + Remote</strong> – 300 THB/day</li>
            <li><strong>Tablet Mount for Prompter</strong> – included with rental</li>
            <li><strong>Teleprompter App (Green Light Studio Login)</strong> – free with rental</li>
          </ul>
        </section>

        <!-- Lighting -->
        <section>
          <h2 class="package-heading" style="text-align: left;">Lighting & Grip</h2>
          <ul class="package-list">
            <li><strong>Godox SL60W (Softbox Kit)</strong> – 250 THB/day</li>
            <li><strong>Yongnuo YN300 III (RGB Panel)</strong> – 150 THB/day</li>
            <li><strong>C-Stand + Boom Arm</strong> – 150 THB/day</li>
            <li><strong>Backdrop Kit (Black/White/Green)</strong> – 300 THB/day</li>
          </ul>
        </section>

        <!-- Booking & Terms -->
        <section>
          <h2 class="package-heading" style="text-align: left;">Booking & Payment</h2>
          <p class="package-paragraph">
            Rentals are offered by <strong>Green Light Studio</strong> and available to Broken Duck Studio members or approved collaborators. Gear is inspected before and after each use. Payment must be made in advance.
          </p>
          <ul class="package-list">
            <li>Bank: <strong>Bangkok Bank</strong></li>
            <li>Account Number: <strong>613-0-418665</strong></li>
            <li><strong>Payment due 2 days before rental</strong></li>
            <li><strong>No refunds</strong> — reschedules only (if available)</li>
          </ul>
        </section>

        <!-- Usage Notes -->
        <section>
          <h2 class="package-heading" style="text-align: left;">Usage Guidelines</h2>
          <p class="package-paragraph">
            Rentals are for use <strong>on-site only</strong> unless approved in writing. Damage, late return, or improper handling may result in additional charges. We recommend you test all gear with your workflow before recording.
          </p>
        </section>

        <!-- Support -->
        <section>
          <h2 class="package-heading" style="text-align: left;">Need Help?</h2>
          <p class="package-paragraph">
            If you need assistance with gear setup or want to include an operator, check out our <a href="/packages" style="color: var(--color-theme); text-decoration: underline;">Production Packages</a>.
          </p>
        </section>
      </div>
    </main>

    <Footer />
  </body>
</html>
